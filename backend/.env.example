# Django Security & Core Settings
SECRET_KEY=your-production-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-production-api-domain.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-production-domain.com

# OpenRouter LLM Settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Database configurations (Used by Docker Compose database and backend)
DB_NAME=docmind
DB_USER=postgres
DB_PASSWORD=your_secure_db_password_here
DB_HOST=db
DB_PORT=5432

# Frontend Build Configurations (Used by Docker Compose frontend service)
NEXT_PUBLIC_BACKEND_URL=http://your-production-domain.com
